# ── Payment Settlement & Transaction Exception Engine ──
# Copy this file to .env and fill in values

# Flask
FLASK_APP=app.py
FLASK_ENV=development        # change to 'production' when deploying
SECRET_KEY=change-this-to-a-long-random-string

# Database
# SQLite (default — no setup needed, good for development)
# DATABASE_URL=sqlite:///payment_engine.db

# MySQL (uncomment and fill for production)
# DATABASE_URL=mysql+pymysql://USERNAME:PASSWORD@HOST:3306/payment_engine

# PostgreSQL (good for Render / Railway / Supabase)
# DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/payment_engine
